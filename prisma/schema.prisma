generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  name           String?
  role           String   @default("user") // user | admin
  approvalStatus String   @default("pending") // pending | approved | rejected
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  accounts BrokerAccount[]
}

model BrokerAccount {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  login            String
  passwordEnc      String
  server           String
  mode             String    @default("live")
  /// pending_registration | provisioning | connected | failed | undeployed
  status           String    @default("pending_registration")
  statusMessage    String?
  syncToken        String?
  lastSyncAt       DateTime?
  metaApiAccountId String?
  metaApiRegion    String?   @default("new-york")
  botEnabled       Boolean   @default(false)
  /// When bot was last turned OFF (null while bot running). Used for 24h idle undeploy.
  botStoppedAt     DateTime?
  /// Cross-process tick mutex (local engine + GHA + Vercel). Stale after ~90s.
  tickLockedAt     DateTime?
  balance          Float     @default(0)
  equity           Float     @default(0)
  startingBalance  Float     @default(0)
  tpCount          Int       @default(0)
  slCount          Int       @default(0)
  cycleCount       Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  config     StrategyConfig?
  symbolBots SymbolBot[]
  strategyLogics StrategyLogic[]
  baskets    Basket[]
  fills      Fill[]
  snapshots  EquitySnapshot[]
  dailyStats DailyStat[]

  @@index([userId])
  @@unique([login])
  @@index([status])
}

/// 계좌별 전략 표 오버라이드 (프리셋 수정 · 커스텀)
model StrategyLogic {
  id        String   @id @default(cuid())
  accountId String
  account   BrokerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  /// dubai_bruno_313(알파지속로직) | martin_9..12 | custom
  logicId   String
  name      String?
  /// { mode, leverageBase, startLots?, takeProfitPct?, stopLossPct?, takeProfitUsd?, stopLossUsd?, levels?: [{lots,profit,drop}] }
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountId, logicId])
  @@index([accountId])
}

/// Per-symbol strategy — multiple can run at once
model SymbolBot {
  id               String  @id @default(cuid())
  accountId        String
  account          BrokerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  symbol           String
  enabled          Boolean @default(true)
  logic            String  @default("dubai_bruno_313")
  direction        String  @default("BUY")
  entryCount       Int     @default(10)
  entryMultiplier  Float   @default(2)
  entryIntervalPct Float   @default(5)
  takeProfitPct    Float   @default(20)
  /// 고정 익절 목표($). 0이면 startLots 증거금 × takeProfitPct/100
  takeProfitUsd    Float   @default(0)
  startLots        Float   @default(0.01)
  repeatEnabled    Boolean @default(true)
  stopLossPct      Float   @default(225)
  /// 고정 손절 한도($). 0이면 startLots 증거금 × stopLossPct/100
  stopLossUsd      Float   @default(0)
  stopLossEnabled  Boolean @default(true)
  stopOnSl         Boolean @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([accountId, symbol])
  @@index([accountId, enabled])
}

model StrategyConfig {
  id               String  @id @default(cuid())
  accountId        String  @unique
  account          BrokerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  /// SuperMeta-style DCA
  symbol           String  @default("EURUSD")
  direction        String  @default("BUY") // BUY | SELL
  entryCount       Int     @default(10) // 1..20
  entryMultiplier  Float   @default(2)
  entryIntervalPct Float   @default(5)
  takeProfitPct    Float   @default(1)
  startLots        Float   @default(0.01)
  repeatEnabled    Boolean @default(true)
  stopLossPct      Float   @default(0)
  stopLossEnabled  Boolean @default(false)
  stopOnSl         Boolean @default(true)
  hedgeEnabled     Boolean @default(false)
  hedgePct         Float   @default(2)
  /// legacy / engine helpers
  baseLots         Float   @default(0.01)
  profitTarget     Float   @default(10)
  profitScale      Float   @default(1)
  maxDcaLevel      Int     @default(9)
  devScale         Float   @default(0.15)
  finalSlExtraPct  Float   @default(5)
  enableFinalSl    Boolean @default(true)
  reenterAfterTp   Boolean @default(true)
  reenterAfterSl   Boolean @default(true)
  symbols          String  @default("EURUSD")
}

model Basket {
  id              String   @id @default(cuid())
  accountId       String
  account         BrokerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  symbol          String
  direction       String
  filledLevel     Int      @default(0)
  firstEntryPrice Float
  status          String   @default("open")
  unrealizedPnl   Float    @default(0)
  realizedPnl     Float    @default(0)
  tradingPaused   Boolean  @default(false)
  lastExitAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  legs BasketLeg[]

  @@index([accountId, symbol, status])
}

model BasketLeg {
  id        String   @id @default(cuid())
  basketId  String
  basket    Basket   @relation(fields: [basketId], references: [id], onDelete: Cascade)
  level     Int
  lots      Float
  price     Float
  createdAt DateTime @default(now())
}

model Fill {
  id        String   @id @default(cuid())
  accountId String
  account   BrokerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  symbol    String
  side      String
  lots      Float
  price     Float
  pnl       Float    @default(0)
  kind      String
  level     Int?
  note      String?
  createdAt DateTime @default(now())

  @@index([accountId, createdAt])
}

model EquitySnapshot {
  id        String   @id @default(cuid())
  accountId String
  account   BrokerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  equity    Float
  balance   Float
  createdAt DateTime @default(now())

  @@index([accountId, createdAt])
}

model DailyStat {
  id          String @id @default(cuid())
  accountId   String
  account     BrokerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  date        String
  startEquity Float
  endEquity   Float
  pnl         Float  @default(0)
  returnPct   Float  @default(0)
  tpCount     Int    @default(0)
  slCount     Int    @default(0)

  @@unique([accountId, date])
}

model PriceTick {
  symbol    String   @id
  bid       Float
  ask       Float
  updatedAt DateTime @updatedAt
}
