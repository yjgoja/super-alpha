{
  "name": "super-alpha",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "engine": "tsx --env-file=.env scripts/tick-direct.ts",
    "engine:http": "tsx --env-file=.env scripts/tick-loop.ts",
    "engine:direct": "tsx --env-file=.env scripts/tick-direct.ts",
    "engine:supervise": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-engine.ps1",
    "engine:verify-guard": "tsx scripts/verify-engine-guard.ts",
    "ticks:record": "tsx --env-file=.env scripts/record-live-ticks.ts",
    "ticks:g1": "tsx --env-file=.env scripts/reprovision-g1-ticks.ts",
    "ticks:import": "tsx scripts/import-mt5-ticks.ts",
    "ticks:backtest": "tsx scripts/_backtest-ticks.ts",
    "seed:admin": "tsx --env-file=.env scripts/seed-admin.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@types/three": "^0.185.1",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3",
    "metaapi.cloud-sdk": "^29.3.3",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.185.1",
    "tsx": "^4.20.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
