{
  "framework": "nextjs",
  "regions": ["iad1"],
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "CDN-Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
