# Always-on DCA worker (5s ticks) — Render / Railway / Fly / 로컬
# 웹을 닫아도 물타기·익절이 거의 실시간에 가깝게 돈다.
FROM node:20-alpine
WORKDIR /app
COPY package.json package-lock.json ./
COPY prisma ./prisma
RUN npm ci --omit=dev && npx prisma generate
COPY scripts ./scripts
COPY src ./src
COPY tsconfig.json ./
ENV NODE_ENV=production
ENV ENGINE_INTERVAL_MS=5000
CMD ["npx", "tsx", "scripts/tick-loop.ts"]
