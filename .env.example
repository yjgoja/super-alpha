# Required — always-on Postgres (Render 등). Neon Free 서버리스 금지(쿼터 시 실계좌 매매 중단).
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
# Optional: engine refuses to start unless host contains this substring
ENGINE_DB_HOST_ALLOW=render.com
# Emergency only — never for live money
# ALLOW_LEGACY_NEON=1
DIRECT_URL=postgresql://user:pass@host/db?sslmode=require
AUTH_SECRET=change-me-min-16-chars
METAAPI_TOKEN=paste-from-https://app.metaapi.cloud/token
CRON_SECRET=long-random-string-for-gha-bot-tick

# Optional
ADMIN_EMAILS=you@example.com
# Set to 1 to skip admin approval on register (default: pending until admin approves)
AUTO_APPROVE_USERS=0

# Free email verification (Resend — https://resend.com , free tier ~100/day)
RESEND_API_KEY=re_xxxxxxxx
# Verified domain sender (after Resend domain DNS)
EMAIL_FROM=슈퍼알파 <noreply@superalpha.kr>
NEXT_PUBLIC_SITE_URL=https://www.superalpha.kr
METAAPI_REGION=new-york
METAAPI_PROFILE_ID=
METAAPI_FORCE_G1=0
# Tick recording / G1 probe (optional)
META_ACCOUNT_ID=
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=ZeroMarkets-Demo
RECORD_SYMBOLS=EURUSD,XAUUSD
RECORD_INTERVAL_MS=1000
ENGINE_INTERVAL_MS=2000
ENGINE_BUDGET_MS=600000
ENGINE_CLOUD_WAIT_MS=45000
ENGINE_MAX_CONSECUTIVE_FAILS=8
BOT_TICK_URL=https://www.superalpha.kr/api/cron/tick
SEED_ADMIN_PASSWORD=

# Live UI speedups (safe defaults). Trading engine always uses fresh MetaAPI snapshots.
# Set LIVE_SNAPSHOT_CACHE_MS=0 to disable UI snapshot TTL cache (rollback).
LIVE_SNAPSHOT_CACHE_MS=2500
# Set LIVE_SSE_ENABLED=0 to disable /api/live/stream (UI falls back to MetaAPI poll only).
LIVE_SSE_ENABLED=1